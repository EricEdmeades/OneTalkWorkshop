# Copy to .env.local for local dev. In production, set these in
# Vercel → Project Settings → Environment Variables.
#
# Both variables are OPTIONAL. If unset, the corresponding tracker
# does not load and no analytics requests fire.

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=

# Meta (Facebook) Pixel ID. The Speaker Nation pixel is 515848329126231 —
# confirm before enabling in production.
VITE_META_PIXEL_ID=
