# Copy to .env.local for local dev. In production, set these in
# Vercel → Project Settings → Environment Variables.

# ─ Analytics (client-side, exposed to browser via Vite's VITE_ prefix) ─
# Both are OPTIONAL. If unset, the corresponding tracker does not load
# and no analytics requests fire.

# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
VITE_GA_MEASUREMENT_ID=

# Meta (Facebook) Pixel ID. The Speaker Nation pixel is 515848329126231 —
# confirm before enabling in production.
VITE_META_PIXEL_ID=

# ─ Keap (server-side only, used by /api/subscribe-otw) ─
# Required for the "5 Steps to Overcoming Stage Fright" lead-magnet form
# to deliver into Keap. Reuses the same Keap account / credentials as
# ericedmeades.com. Locally, use `vercel dev` so the serverless function
# runs against these env vars.

# Keap REST API key (https://api.infusionsoft.com)
KEAP_API_KEY=

# Keap tag ID that triggers the 5 Steps email + worksheet delivery
# automation. Do NOT change this in Keap — the automation is wired to
# this exact tag. Default 1831 works as a fallback if unset.
KEAP_TAG_ID_STAGE_FRIGHT=1831
